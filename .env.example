# DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/tidur_plus_db"

# JWT
JWT_SECRET=ganti_dengan_secret_panjang_random
JWT_REFRESH_SECRET=ganti_dengan_refresh_secret_panjang_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=isi_dari_google_console
GOOGLE_CLIENT_SECRET=isi_dari_google_console
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# APP
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# STORAGE
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
