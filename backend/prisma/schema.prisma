generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ANGGOTA
  ADMIN
  SUPER_ADMIN
}

enum StatusPeminjaman {
  MENUNGGU
  DIPINJAM
  DIKEMBALIKAN
  DITOLAK
}

enum StatusPerpanjangan {
  MENUNGGU
  DISETUJUI
  DITOLAK
}

enum StatusDenda {
  BELUM_LUNAS
  LUNAS
}

model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique
  nama      String
  email     String   @unique
  foto      String?
  roles     Role[]   @default([ANGGOTA])
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  peminjaman           Peminjaman[]
  auditLog             AuditLog[]
  perpanjanganDiproses Perpanjangan[] @relation("PerpanjanganAdmin")
  dendaDiproses        Denda[]        @relation("DendaAdmin")

  @@index([aktif])
}

model Kategori {
  id        String   @id @default(cuid())
  nama      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buku Buku[]
}

model Buku {
  id          String   @id @default(cuid())
  judul       String
  penulis     String
  penerbit    String?
  tahunTerbit Int?
  isbn        String?  @unique
  stok        Int      @default(0)
  cover       String?
  deskripsi   String?
  kategoriId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kategori   Kategori     @relation(fields: [kategoriId], references: [id])
  peminjaman Peminjaman[]

  @@index([kategoriId])
  @@index([judul])
  @@index([penulis])
  @@index([stok])
}

model Peminjaman {
  id                  String           @id @default(cuid())
  userId              String
  bukuId              String
  tanggalPinjam       DateTime?
  tanggalKembali      DateTime?
  batasKembali        DateTime?
  status              StatusPeminjaman @default(MENUNGGU)
  counterPerpanjangan Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  buku         Buku           @relation(fields: [bukuId], references: [id])
  perpanjangan Perpanjangan[]
  denda        Denda?

  @@index([userId])
  @@index([bukuId])
  @@index([batasKembali])
}

model Perpanjangan {
  id           String             @id @default(cuid())
  peminjamanId String
  adminId      String?
  jumlahHari   Int
  status       StatusPerpanjangan @default(MENUNGGU)
  tglDiproses  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  peminjaman Peminjaman @relation(fields: [peminjamanId], references: [id])
  admin      User?      @relation("PerpanjanganAdmin", fields: [adminId], references: [id])

  @@index([peminjamanId])
  @@index([adminId])
}

model Denda {
  id              String      @id @default(cuid())
  peminjamanId    String      @unique
  adminId         String?
  jumlah          Float
  jumlahHariTelat Int
  tarifPerHari    Float
  status          StatusDenda @default(BELUM_LUNAS)
  tglLunas        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  peminjaman Peminjaman @relation(fields: [peminjamanId], references: [id])
  admin      User?      @relation("DendaAdmin", fields: [adminId], references: [id])

  @@index([adminId])
}

model Konfigurasi {
  id              String   @id @default(cuid())
  tarifDenda      Float    @default(1000)
  durasiPinjam    Int      @default(14)
  maxPerpanjangan Int      @default(2)
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  aksi      String
  detail    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}